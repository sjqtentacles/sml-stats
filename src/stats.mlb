(* MLB for the sml-stats library: the vendored sml-prng generators plus the
 * statistics sources. Consumers reference this file.
 *
 * The dependency .mlb is brought in WITHOUT a `local` wrapper so that
 * consumers (the test suite, examples) can name the generator structures
 * (e.g. SplitMix64) alongside Stats. *)
$(SML_LIB)/basis/basis.mlb
../lib/github.com/sjqtentacles/sml-prng/prng.mlb
stats.sig
stats.sml
